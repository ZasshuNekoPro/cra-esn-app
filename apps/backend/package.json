{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "dev": "nest start --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed": "ts-node prisma/seed.ts",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "seed:prod": "ts-node --transpile-only prisma/seed.prod.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/lib-storage": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@esn/pdf-generator": "workspace:^",
    "@esn/rag-engine": "workspace:^",
    "@esn/shared-types": "workspace:^",
    "@esn/shared-utils": "workspace:^",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.2",
    "@prisma/client": "^5.13.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "file-type": "^21.3.3",
    "ioredis": "^5.3.2",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@swc/core": "^1.6.1",
    "@swc/helpers": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^6.4.15",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.6.0",
    "prisma": "^5.13.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "unplugin-swc": "^1.4.4",
    "vitest": "^1.6.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
