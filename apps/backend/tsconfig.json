{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@esn/shared-types": ["../../packages/shared-types/src"],
      "@esn/shared-types/*": ["../../packages/shared-types/src/*"],
      "@esn/shared-utils": ["../../packages/shared-utils/src"],
      "@esn/shared-utils/*": ["../../packages/shared-utils/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
