{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "paths": {
      "@esn/shared-types": ["../../packages/shared-types/src"],
      "@esn/shared-types/*": ["../../packages/shared-types/src/*"],
      "@esn/shared-utils": ["../../packages/shared-utils/src"],
      "@esn/shared-utils/*": ["../../packages/shared-utils/src/*"],
      "@esn/pdf-generator": ["../../packages/pdf-generator/src"],
      "@esn/pdf-generator/*": ["../../packages/pdf-generator/src/*"],
      "@esn/rag-engine": ["../../packages/rag-engine/src"],
      "@esn/rag-engine/*": ["../../packages/rag-engine/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
