# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://esn_user:password@localhost:5433/esn_cra_dev"
DATABASE_URL_TEST="postgresql://esn_user:password@localhost:5433/esn_cra_test"

# ── Authentification ───────────────────────────────────────────────────────────
JWT_SECRET="changeme-min-32-chars-jwt-secret-key"
JWT_EXPIRATION="7d"
NEXTAUTH_SECRET="changeme-min-32-chars-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── Stockage S3 (MinIO en développement) ──────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET_NAME="esn-cra-documents"
S3_REGION="eu-west-3"

# ── Intelligence Artificielle (RAG) ───────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api..."
OPENAI_API_KEY="sk-..."
PGVECTOR_DIMENSIONS="1536"

# ── Notifications email ────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@esn-cra.app"
SMTP_PASS="your-smtp-password"
SMTP_FROM="ESN CRA App <noreply@esn-cra.app>"

# ── Application ───────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6380"

NODE_ENV="development"
BACKEND_PORT="3001"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# ── Sécurité ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS="12"
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"
CORS_ORIGIN="http://localhost:3000"

# ── Règles métier (projets) ────────────────────────────────────────────────────
WEATHER_ESCALATION_DAYS="3"
SIGNATURE_REMINDER_DAYS="3"
SHARE_LINK_EXPIRATION_HOURS="48"
