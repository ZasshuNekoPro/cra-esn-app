# ESN CRA App — Production environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file and fill in every value in your Coolify project settings.
# NEVER commit a filled .env file to git.
#
# Generate secrets:  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL with pgvector extension) ─────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
# In Coolify, HOST = internal service name (e.g. "postgres")
DATABASE_URL=

# Prisma runs `prisma migrate deploy` automatically at backend startup.

# ── Authentication ────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Full public URL of the frontend (https://...)
NEXTAUTH_URL=
# Generate: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRATION=7d

# ── Inter-service URLs ────────────────────────────────────────────────────────
# Public URL of the frontend
FRONTEND_URL=
# Public URL of the frontend (used for CORS on the backend)
CORS_ORIGIN=
# INTERNAL Docker URL of the backend (service-to-service, not the public domain)
# Example: http://backend:3001
BACKEND_URL=

# ── S3 File Storage ───────────────────────────────────────────────────────────
# Use 's3' for production (MinIO or compatible), 'local' for dev only
STORAGE_DRIVER=s3
# MinIO internal URL: http://minio:9000
# OVH Object Storage: https://s3.gra.io.cloud.ovh.net
# Scaleway:           https://s3.fr-par.scw.cloud
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=esn-cra-documents
S3_REGION=eu-west-3

# ── Redis ─────────────────────────────────────────────────────────────────────
# Internal URL: redis://redis:6379
REDIS_URL=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ESN CRA App <noreply@esn-cra.app>

# ── AI / RAG (Anthropic Claude) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Admin initialization (seed.prod.ts — run once after first deployment) ─────
# Email of the first ESN_ADMIN account
ADMIN_EMAIL=
# Strong password: min 12 chars, mix of upper/lower/digits/symbols
ADMIN_PASSWORD=

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=3001
BCRYPT_ROUNDS=12

# ── PostgreSQL (used by docker-compose.prod.yml only — not needed in Coolify) ─
POSTGRES_USER=esn_user
POSTGRES_PASSWORD=
POSTGRES_DB=esn_cra
